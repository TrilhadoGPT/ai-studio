GHCR_USERNAME=SEU_USUARIO_GITHUB
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
AI_STUDIO_IMAGE=ghcr.io/SEU_USER/ai-studio:latest
AI_STUDIO_CONTAINER_NAME=ai-studio
HOST_PORT_HTTP=80
HOST_PORT_IMAGE=8000
HOST_PORT_VIDEO=8001
FLUX_PRECISION=bf16
LTX_PRECISION=bf16
LOW_VRAM=false

# Host mode (sem Docker)
VENV_DIR=/workspace/ai-studio/.venv
FLUX_MODEL_PATH=/workspace/ai-studio/models/flux
LTX_MODEL_PATH=/workspace/ai-studio/models/ltx
OUTPUT_DIR=/workspace/ai-studio/outputs/images
VIDEO_OUTPUT_DIR=/workspace/ai-studio/outputs/videos
IMAGE_OUTPUT_DIR=/workspace/ai-studio/outputs/images
UPLOAD_DIR=/workspace/ai-studio/uploads
ENABLE_VIDEO=false
ENABLE_IMAGE=true
DOWNLOAD_FLUX=true
DOWNLOAD_LTX=false
